# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Docker PostgreSQL configuration (used by docker-compose.yml)
MEDMENTOR_POSTGRES_DB=medmentor
MEDMENTOR_POSTGRES_USER=medmentor
MEDMENTOR_POSTGRES_PASSWORD=medmentor123

# Ollama base URL override (Docker default: http://ollama:11434)
# SPRING_AI_OLLAMA_BASE_URL=http://localhost:11434

# Planned local-first auth bootstrap
# The backend will use these credentials to create or load the single local user
# on first startup once auth is implemented.
MEDMENTOR_DEFAULT_USERNAME=doctor
MEDMENTOR_DEFAULT_PASSWORD=change_me
MEDMENTOR_DEFAULT_DISPLAY_NAME="Local Doctor"

# Comma-separated frontend origins allowed to send credentialed API requests.
MEDMENTOR_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Optional override if the backend needs a non-default path to the repository cases folder.
MEDMENTOR_CASES_PATH=../cases

# RAG source data folder and sync behavior.
MEDMENTOR_RAG_ENABLED=true
MEDMENTOR_RAG_SOURCE_PATH=../rag-data
MEDMENTOR_RAG_SYNC_INTERVAL_MS=30000
MEDMENTOR_RAG_TOP_K=5

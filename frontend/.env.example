# Optional override of the backend base URL for REST and WebSocket.
#
# Leave empty (or unset) for the default same-origin setup, where REST `/api/*`
# and WebSocket `/ws` are served from the same origin as the SPA. That covers:
#   - local dev: Vite dev server on :5173 with `server.proxy` forwarding to :8080
#   - docker / single-port reverse proxy (ngrok, nginx, ...)
#
# Set this only when the SPA is hosted on a different origin than the backend
# (cross-origin). In that case the origin must also be added to the backend
# `MEDMENTOR_ALLOWED_ORIGINS` env var.
#
# VITE_API_BASE_URL=http://localhost:8080
